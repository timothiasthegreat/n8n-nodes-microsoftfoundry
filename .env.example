# Microsoft Foundry smoke-test configuration.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Base URL of your Foundry resource (no trailing /openai or /anthropic).
FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com

# API key for the Foundry resource.
FOUNDRY_API_KEY=your-api-key-here

# Deployment names to test against each wire protocol.
FOUNDRY_OPENAI_DEPLOYMENT=Kimi-K2.6
FOUNDRY_ANTHROPIC_DEPLOYMENT=claude-opus-4-8
