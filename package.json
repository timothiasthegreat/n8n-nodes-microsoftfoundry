{
  "name": "n8n-nodes-microsoftfoundry",
  "version": "0.2.0",
  "description": "n8n community node to use any Microsoft Foundry model deployment (OpenAI, Anthropic/Claude, DeepSeek, Kimi, and more) as a chat model for AI Agents",
  "license": "MIT",
  "homepage": "https://github.com/timothiasthegreat/n8n-nodes-microsoftfoundry",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "microsoft-foundry",
    "azure-ai-foundry",
    "ai",
    "llm",
    "chat-model",
    "anthropic",
    "openai"
  ],
  "author": {
    "name": "Timothy McBride",
    "email": "tim@firesideit.ca"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/timothiasthegreat/n8n-nodes-microsoftfoundry.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "aiNodeSdkVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/MicrosoftfoundryApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Microsoftfoundry/MicrosoftFoundryChatModel.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/ai-node-sdk": "^0.19.8",
    "@n8n/node-cli": "^0.38.8",
    "eslint": "9.32.0",
    "n8n-workflow": "^2.29.3",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "@n8n/ai-node-sdk": "*",
    "n8n-workflow": "*"
  }
}
